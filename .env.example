# Supabase PostgreSQL — usa Transaction pooler (puerto 6543) en producción
# Session pooler (5432) limita conexiones (~15); Render + Hikari las agota rápido
DB_HOST=aws-1-us-east-2.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-password-here
DB_SSLMODE=require
DB_POOL_MAX=5
DB_POOL_MIN=1

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-min-256-bits
JWT_EXPIRATION_MS=86400000

# Server
SERVER_PORT=8080
